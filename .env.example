# ============================================
# Required
# ============================================
PINATA_JWT=

# ============================================
# Optional — Customization / Whitelabeling
# ============================================

# Max file size in MB (default: 10)
# NEXT_PUBLIC_MAX_FILE_SIZE_MB=10

# IPFS gateway URL for fetching files (default: https://gateway.pinata.cloud)
# NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud

# Brand name shown in navbar and page title (default: BurnerDrop)
# NEXT_PUBLIC_BRAND_NAME=BurnerDrop

# Brand tagline shown in hero section (default: Zero-Trust File Transfer · Powered by IPFS)
# NEXT_PUBLIC_BRAND_TAGLINE=Zero-Trust File Transfer · Powered by IPFS

# GitHub repository URL — shown in UI. Remove to hide the link.
# NEXT_PUBLIC_GITHUB_URL=https://github.com/hawkeye-exe/burner-drop